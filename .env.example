# Copy to .env.local and fill in. Never commit .env.local.

# --- Supabase (new unified project) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-only. Used by AI scoring / privileged writes. NEVER expose to the client.
SUPABASE_SERVICE_ROLE_KEY=

# --- AI (Learnbook: OpenAI; Rekhachitra: Anthropic + others, BYOK) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Desmos (Rekhachitra). Defaults to Desmos's public demo key. ---
NEXT_PUBLIC_DESMOS_API_KEY=

# --- Google Sheets import (ported from flippity-clone; optional) ---
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
